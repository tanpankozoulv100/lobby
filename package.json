{
  "name": "lobby-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/show-dev-urls.mjs && next dev --webpack",
    "dev:mobile": "node scripts/show-dev-urls.mjs && next dev --webpack -H 0.0.0.0 -p 3000",
    "dev:turbo": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "start:mobile": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:storage": "firebase deploy --only storage",
    "deploy:rules": "firebase deploy --only firestore,storage",
    "deploy:functions": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "html5-qrcode": "^2.3.8",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-qr-code": "^2.0.18"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
