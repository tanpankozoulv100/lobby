rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /** ドキュメント ID ＝ Firebase Auth の uid。中身は空でも可。運営は Console で 1 件だけ作ればよい。 */
    function isLobbyStaff() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow list, create, update, delete: if false;
    }

    /** ユーザーからの通報（運営は別サイトの Admin SDK で一覧想定。本人は自分の reporterUid のみ read 可） */
    match /userReports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['reporterUid', 'reportedUid', 'reasonCode', 'note', 'createdAt'])
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reportedUid is string
        && request.resource.data.reportedUid != request.auth.uid
        && request.resource.data.reasonCode in ['harassment', 'spam', 'inappropriate', 'other']
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 500
        && request.resource.data.createdAt is timestamp;

      allow read: if request.auth != null && (
        isLobbyStaff() ||
        resource.data.reporterUid == request.auth.uid
      );

      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['displayName', 'bio', 'createdAt', 'updatedAt', 'participantNo', 'participantSerial', 'identityStatus'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 50
        && request.resource.data.bio is string
        && request.resource.data.bio.size() <= 500
        && request.resource.data.participantNo is int
        && request.resource.data.participantNo >= 1
        && request.resource.data.participantNo <= 999
        && request.resource.data.participantSerial is string
        && request.resource.data.participantSerial.size() >= 1
        && request.resource.data.participantSerial.size() <= 32
        && request.resource.data.identityStatus == 'none';
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'bio', 'updatedAt'])
            && request.resource.data.displayName is string
            && request.resource.data.displayName.size() > 0
            && request.resource.data.displayName.size() <= 50
            && request.resource.data.bio is string
            && request.resource.data.bio.size() <= 500
          )
          || (
            !resource.data.keys().hasAny(['participantNo'])
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantNo', 'participantSerial', 'updatedAt'])
            && request.resource.data.participantNo is int
            && request.resource.data.participantNo >= 1
            && request.resource.data.participantNo <= 999
            && request.resource.data.participantSerial is string
            && request.resource.data.participantSerial.size() >= 1
            && request.resource.data.participantSerial.size() <= 32
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['identityStatus', 'idDocumentPath', 'identitySubmittedAt', 'updatedAt'])
            && request.resource.data.identityStatus == 'pending'
            && request.resource.data.idDocumentPath is string
            && request.resource.data.idDocumentPath.matches('^users/' + userId + '/identity/[^/]+$')
            && (
              !resource.data.keys().hasAny(['identityStatus'])
              || resource.data.identityStatus in ['none', 'pending', 'rejected']
            )
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ticketRedeemedAt', 'seasonTicketCode', 'updatedAt'])
            && request.resource.data.seasonTicketCode is string
            && request.resource.data.seasonTicketCode.size() >= 8
            && request.resource.data.seasonTicketCode.size() <= 64
            && !resource.data.keys().hasAny(['ticketRedeemedAt'])
          )
        );

      match /eventSignups/{signupId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && (
            request.resource.data.keys().hasOnly(['eventId', 'dateKey', 'period', 'slotChoiceId', 'updatedAt'])
            || request.resource.data.keys().hasOnly(['eventId', 'dateKey', 'period', 'slotChoiceId', 'updatedAt', 'cohortAtSignup', 'destinationLabelAtSignup'])
          )
          && request.resource.data.eventId is string
          && request.resource.data.eventId.size() >= 1
          && request.resource.data.eventId.size() <= 256
          && request.resource.data.dateKey is string
          && request.resource.data.dateKey.matches('^[0-9]{8}$')
          && request.resource.data.period in ['morning', 'afternoon', 'evening']
          && request.resource.data.slotChoiceId is string
          && request.resource.data.slotChoiceId.size() >= 1
          && request.resource.data.slotChoiceId.size() <= 128
          && (!request.resource.data.keys().hasAny(['cohortAtSignup']) || request.resource.data.cohortAtSignup in ['A', 'B'])
          && (!request.resource.data.keys().hasAny(['destinationLabelAtSignup'])
            || (request.resource.data.destinationLabelAtSignup is string
              && request.resource.data.destinationLabelAtSignup.size() >= 1
              && request.resource.data.destinationLabelAtSignup.size() <= 500));
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /cohortWeeks/{weekKey} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /blockedUsers/{blockedUid} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && blockedUid != userId
          && request.resource.data.keys().hasOnly(['createdAt'])
          && request.resource.data.createdAt is timestamp;
        allow delete: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
      }

      match /dateInviteTickets/{ticketId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && ticketId.matches('^m[0-9]+$')
          && request.resource.data.keys().hasOnly(['milestoneMatches', 'grantedAt', 'expiresAt', 'consumedAt', 'consumedByInviteId'])
          && request.resource.data.milestoneMatches is int
          && request.resource.data.milestoneMatches >= 10
          && request.resource.data.milestoneMatches % 10 == 0
          && request.resource.data.milestoneMatches <= 1000
          && request.resource.data.expiresAt is timestamp
          && request.resource.data.expiresAt > request.time
          && request.resource.data.expiresAt <= request.time + duration.value(73, 'h')
          && request.resource.data.consumedAt == null
          && request.resource.data.consumedByInviteId == null;
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['consumedAt', 'consumedByInviteId'])
          && request.resource.data.consumedAt is timestamp
          && request.resource.data.consumedByInviteId is string
          && request.resource.data.consumedByInviteId.size() >= 1
          && resource.data.consumedAt == null
          && resource.data.consumedByInviteId == null;
        allow delete: if false;
      }

      match /dateInvites/{inviteId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['toUid', 'location', 'proposedAt', 'message', 'ticketId', 'createdAt'])
          && request.resource.data.toUid is string
          && request.resource.data.toUid != userId
          && request.resource.data.location is string
          && request.resource.data.location.size() >= 1
          && request.resource.data.location.size() <= 300
          && request.resource.data.proposedAt is timestamp
          && request.resource.data.ticketId is string
          && request.resource.data.ticketId.size() >= 1
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 500
          && exists(/databases/$(database)/documents/users/$(userId)/outboundLinks/$(request.resource.data.toUid))
          && !exists(/databases/$(database)/documents/users/$(userId)/blockedUsers/$(request.resource.data.toUid));
        allow update, delete: if false;
      }
    }

    match /ticketCodes/{code} {
      allow read: if request.auth != null && (
        !resource.data.keys().hasAny(['usedBy'])
        || resource.data.usedBy == null
        || resource.data.usedBy == request.auth.uid
      );
      allow create, delete: if false;
      allow update: if request.auth != null
        && (!resource.data.keys().hasAny(['usedBy']) || resource.data.usedBy == null)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy'])
        && request.resource.data.usedBy == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if request.auth != null && (
        resource.data.isPublished == true ||
        isLobbyStaff()
      );

      allow create: if isLobbyStaff()
        && request.resource.data.keys().hasAll(['title', 'startsAt', 'isPublished', 'createdAt'])
        && request.resource.data.keys().hasOnly(['title', 'startsAt', 'endsAt', 'description', 'locationSummary', 'isPublished', 'createdAt'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 300
        && request.resource.data.isPublished is bool
        && request.resource.data.startsAt is timestamp
        && request.resource.data.createdAt is timestamp
        && (!request.resource.data.keys().hasAny(['description'])
          || (request.resource.data.description is string && request.resource.data.description.size() <= 8000))
        && (!request.resource.data.keys().hasAny(['endsAt']) || request.resource.data.endsAt is timestamp)
        && (!request.resource.data.keys().hasAny(['locationSummary'])
          || (request.resource.data.locationSummary is string && request.resource.data.locationSummary.size() <= 500));

      allow update: if isLobbyStaff()
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().hasAll(['title', 'startsAt', 'isPublished', 'createdAt'])
        && request.resource.data.keys().hasOnly(['title', 'startsAt', 'endsAt', 'description', 'locationSummary', 'isPublished', 'createdAt'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 300
        && request.resource.data.isPublished is bool
        && request.resource.data.startsAt is timestamp
        && request.resource.data.createdAt is timestamp
        && (!request.resource.data.keys().hasAny(['description'])
          || (request.resource.data.description is string && request.resource.data.description.size() <= 8000))
        && (!request.resource.data.keys().hasAny(['endsAt']) || request.resource.data.endsAt is timestamp)
        && (!request.resource.data.keys().hasAny(['locationSummary'])
          || (request.resource.data.locationSummary is string && request.resource.data.locationSummary.size() <= 500));

      allow delete: if false;

      match /slotChoices/{slotId} {
        allow read: if request.auth != null && (
          isLobbyStaff() ||
          get(/databases/$(database)/documents/events/$(eventId)).data.isPublished == true
        );

        allow create: if isLobbyStaff()
          && exists(/databases/$(database)/documents/events/$(eventId))
          && (
            request.resource.data.keys().hasOnly(['dateKey', 'period', 'cohort', 'lineIndex', 'destinationLabel'])
            || request.resource.data.keys().hasOnly(['dateKey', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'sortOrder'])
            || request.resource.data.keys().hasOnly(['dateKey', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'eventDetail'])
            || request.resource.data.keys().hasOnly(['dateKey', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'eventDetail', 'sortOrder'])
            || request.resource.data.keys().hasOnly(['dateKey', 'startTime', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'eventDetail'])
            || request.resource.data.keys().hasOnly(['dateKey', 'startTime', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'eventDetail', 'sortOrder'])
          )
          && request.resource.data.dateKey is string
          && request.resource.data.dateKey.matches('^[0-9]{8}$')
          && (!request.resource.data.keys().hasAny(['startTime'])
            || (request.resource.data.startTime is string
              && request.resource.data.startTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')))
          && request.resource.data.period in ['morning', 'afternoon', 'evening']
          && request.resource.data.cohort in ['A', 'B']
          && request.resource.data.lineIndex is int
          && request.resource.data.lineIndex in [0, 1]
          && request.resource.data.destinationLabel is string
          && request.resource.data.destinationLabel.size() > 0
          && request.resource.data.destinationLabel.size() <= 500
          && (!request.resource.data.keys().hasAny(['eventDetail'])
            || (request.resource.data.eventDetail is string && request.resource.data.eventDetail.size() <= 2000))
          && (!request.resource.data.keys().hasAny(['sortOrder']) || request.resource.data.sortOrder is int);

        allow update: if isLobbyStaff()
          && (
            request.resource.data.keys().hasOnly(['dateKey', 'period', 'cohort', 'lineIndex', 'destinationLabel'])
            || request.resource.data.keys().hasOnly(['dateKey', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'sortOrder'])
            || request.resource.data.keys().hasOnly(['dateKey', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'eventDetail'])
            || request.resource.data.keys().hasOnly(['dateKey', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'eventDetail', 'sortOrder'])
            || request.resource.data.keys().hasOnly(['dateKey', 'startTime', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'eventDetail'])
            || request.resource.data.keys().hasOnly(['dateKey', 'startTime', 'period', 'cohort', 'lineIndex', 'destinationLabel', 'eventDetail', 'sortOrder'])
          )
          && request.resource.data.dateKey is string
          && request.resource.data.dateKey.matches('^[0-9]{8}$')
          && (!request.resource.data.keys().hasAny(['startTime'])
            || (request.resource.data.startTime is string
              && request.resource.data.startTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')))
          && request.resource.data.period in ['morning', 'afternoon', 'evening']
          && request.resource.data.cohort in ['A', 'B']
          && request.resource.data.lineIndex is int
          && request.resource.data.lineIndex in [0, 1]
          && request.resource.data.destinationLabel is string
          && request.resource.data.destinationLabel.size() > 0
          && request.resource.data.destinationLabel.size() <= 500
          && (!request.resource.data.keys().hasAny(['eventDetail'])
            || (request.resource.data.eventDetail is string && request.resource.data.eventDetail.size() <= 2000))
          && (!request.resource.data.keys().hasAny(['sortOrder']) || request.resource.data.sortOrder is int);

        allow delete: if isLobbyStaff();
      }
    }

    match /announcements/{announcementId} {
      allow read: if request.auth != null && resource.data.isPublished == true;
      allow write: if false;
    }

    match /eventDisplayWindow/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ドキュメント ID ＝ 表示用コード（6 文字想定）。ownerUid のみ。
    match /connectionCodes/{code} {
      allow get: if request.auth != null;
      // ensureMyConnectionCode が ownerUid でクエリするため、本人のコードだけ list 可
      allow list: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/connectionCodes/$(code))
        && request.resource.data.keys().hasOnly(['ownerUid'])
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /users/{userId}/outboundLinks/{peerId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && peerId != userId
        && request.resource.data.keys().hasOnly(['createdAt']);
      allow update, delete: if false;
    }

    // 相手があなたのコードで連携したとき、相手 UID をここに記録（作成は連携した本人のみ）
    match /users/{userId}/linkedFrom/{sourceUid} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == sourceUid
        && sourceUid != userId
        && request.resource.data.keys().hasOnly(['createdAt']);
      allow update, delete: if false;
    }

    match /boardPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['authorUid', 'authorDisplayName', 'body', 'createdAt'])
        && request.resource.data.authorUid is string
        && request.resource.data.authorDisplayName is string
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 500;
      allow update, delete: if false;
    }
  }
}
